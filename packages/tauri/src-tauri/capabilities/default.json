{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "notification:default",
    "fs:default",
    "fs:allow-download-write",
    "dialog:default",
    "dialog:allow-save",
    "core:window:allow-set-fullscreen"
  ]
}
